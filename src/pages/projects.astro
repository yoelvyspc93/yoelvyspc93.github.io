---
import Layout from '@/layouts/Layout.astro'
import IntroWrapper from '@/shared/IntroWrapper.astro'
import Hero from '@/sections/projects/Hero.astro'
import ProjectsList from '@/sections/projects/ProjectsList.astro'

const pageTitle = 'Projects | Yoelvys Perez Cabrera'
const pageDescription =
	"A complete selection of projects I've built, from product landings to full web platforms."

const heroContent = {
	title: 'Projects',
	description:
		"A complete selection of projects I've built, from product landings to full web platforms.",
}
---

<Layout title={pageTitle} description={pageDescription} canonical="/projects/">
	<main id="main-content">
		<Hero content={heroContent} />
		<ProjectsList />
	</main>
</Layout>
