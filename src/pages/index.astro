---
import Layout from '@/layouts/Layout.astro'
import Projects from '@/sections/home/Projects.astro'
import Experience from '@/sections/home/Experience.astro'
import Skills from '@/sections/home/Skills.astro'
import Contact from '@/sections/home/Contact.astro'
import Faq from '@/sections/home/Faq.astro'
import Footer from '@/shared/Footer.astro'
import StickyFooterWrapper from '@/shared/StickyFooterWrapper.astro'

import home from '@/content/home.json'
import contact from '@/content/contact.json'
import layout from '@/content/layout.json'
import IntroWrapper from '@/shared/IntroWrapper.astro'
import Hero from '@/sections/home/Hero.astro'
import About from '@/sections/home/About.astro'

const { links, copyrightName, rightsLabel } = layout
---

<Layout hideFooter={true}>
	<main id="main-content">
		<IntroWrapper>
			<Hero content={home.hero} />
			<About content={home.about} />
		</IntroWrapper>
		<Projects content={home.projects} />
		<Experience content={home.experience} />
		<Skills content={home.skills} />
		<Faq content={home.faq} />
	</main>
	<StickyFooterWrapper>
		<Contact slot="contact" content={home.contact} meta={contact} />
		<Footer slot="footer" data={{ copyrightName, rightsLabel, links }} />
	</StickyFooterWrapper>
</Layout>
