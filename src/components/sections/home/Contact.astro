---
import Button from '@/ui/Button.astro'
import InputField from '@/ui/InputField.astro'
import TextAreaField from '@/ui/TextAreaField.astro'
type Props = {
	content: {
		title: string
		body: string[]
		form: {
			errors: {
				emailRequired: string
				emailInvalid: string
				messageRequired: string
			}
		}
	}
	meta: {
		socials: { platform: string; url: string }[]
		form: { to: string; subject: string }
	}
}

const { content, meta } = Astro.props
const { form } = content
const { subject: SUBJECT } = meta.form
const { errors } = form
const WEB3FORMS_ACCESS_KEY = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY ?? ''
const formAriaLabel = 'Contact form'
const socialsLabel = 'Social links'
const emailLabel = 'Email'
const emailPlaceholder = 'Your email'
const messageLabel = 'Message'
const formStatusSuccess = 'Message sent successfully.'
const formErrorMessage = 'Sending failed. Please try again in a moment.'
const formStatusMissingKey =
	'This form is not configured yet. Add the Web3Forms access key to enable submissions.'
const formStatusSending = 'Sending your message...'
const messagePlaceholders = [
	'Write your message here...',
	'Tell me about your project',
	'How can I help you?',
	'Share your idea or request',
]
const submitLabel = 'Send Message'

const titleWords = content.title.trim().split(/\s+/)
const accentWord =
	titleWords.length > 1 ? titleWords[titleWords.length - 1] : ''
const baseTitle = accentWord ? titleWords.slice(0, -1).join(' ') : content.title

const socialIcons: Record<string, { viewBox: string; path: string }> = {
	github: {
		viewBox: '0 0 24 24',
		path: 'M12 .297a12 12 0 0 0-3.794 23.385c.6.113.82-.258.82-.577v-2.234c-3.338.726-4.043-1.417-4.043-1.417-.546-1.387-1.333-1.756-1.333-1.756-1.089-.744.082-.729.082-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.809 1.304 3.495.997.108-.775.418-1.305.761-1.605-2.666-.303-5.467-1.334-5.467-5.932 0-1.31.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.56 11.56 0 0 1 3.006-.404c1.02.005 2.047.138 3.006.404 2.293-1.552 3.3-1.23 3.3-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.61-2.804 5.625-5.476 5.921.43.37.823 1.102.823 2.222v3.293c0 .322.218.694.825.576A12 12 0 0 0 12 .297z',
	},
	linkedin: {
		viewBox: '0 0 24 24',
		path: 'M4.983 3.5C4.983 4.88 3.862 6 2.482 6A2.49 2.49 0 0 1 0 3.5 2.49 2.49 0 0 1 2.482 1a2.5 2.5 0 0 1 2.501 2.5zM4.96 8H0v15h4.96V8zm7.92 0H8v15h4.88v-7.875c0-2.06 1.72-3.125 3.08-3.125 1.33 0 3.04.79 3.04 3.125V23H24v-8.94C24 9.3 21.3 8 18.96 8c-2.34 0-3.77 1.32-4.08 1.86V8z',
	},
}

const resolveSocialIcon = (platform: string) => {
	const key = platform.toLowerCase().replace(/\s+/g, '')
	return socialIcons[key] ?? null
}

const socialFallbackLabel = (platform: string) => {
	const short = platform.trim().slice(0, 2)
	return short ? short.toUpperCase() : '?'
}
---

<section
	data-sticky-contact-section
	aria-labelledby="contact-title"
	class="section-container lg:min-h-[calc(100svh-90px)] bg-surface-soft px-4 pt-12 pb-8 sm:pt-16 sm:pb-12 md:pt-20 md:pb-16"
>
	<div
		data-contact-layout
		class="mx-auto grid w-full max-w-[560px] lg:max-w-7xl grid-cols-1 items-start gap-8 sm:gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,520px)] lg:gap-16"
	>
		<article class="w-full max-w-[560px]">
			<header>
				<h2
					id="contact-title"
					class="mb-5 font-display text-heading-2 font-bold text-black"
				>
					{baseTitle}
					{accentWord && <span> {accentWord}</span>}
				</h2>
			</header>

			<div
				class="mb-7 flex max-w-[520px] flex-col gap-3 text-medium leading-relaxed text-black/80 sm:mb-10 sm:gap-4"
			>
				{content.body.map((paragraph) => <p>{paragraph}</p>)}
			</div>

			<nav aria-label={socialsLabel}>
				<ul class="flex list-none flex-row gap-3 p-0">
					{
						meta.socials.map((sm) => {
							const icon = resolveSocialIcon(sm.platform)

							return (
								<li>
									<a
										aria-label={sm.platform}
										href={sm.url}
										target="_blank"
										rel="noopener noreferrer"
										class="inline-flex size-9 items-center justify-center rounded-md bg-primary text-white shadow-small transition-transform duration-200 hover:-translate-y-0.5 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/60"
									>
										<span class="sr-only">{sm.platform}</span>
										{icon ? (
											<svg
												aria-hidden="true"
												viewBox={icon.viewBox}
												class="size-4 fill-current"
											>
												<path d={icon.path} />
											</svg>
										) : (
											<span
												aria-hidden="true"
												class="text-[11px] font-semibold uppercase leading-none"
											>
												{socialFallbackLabel(sm.platform)}
											</span>
										)}
									</a>
								</li>
							)
						})
					}
				</ul>
			</nav>
		</article>

		<form
			id="contact-form"
			class="w-full rounded-[20px] border border-black/10 bg-white px-4 py-4 shadow-[0_8px_18px_rgba(0,0,0,0.12)] sm:px-6 sm:py-6 lg:max-w-[520px]"
			aria-label={formAriaLabel}
			data-access-key={WEB3FORMS_ACCESS_KEY}
			data-subject={SUBJECT}
			data-submit-label={submitLabel}
			data-sending-label={formStatusSending}
			data-success-message={formStatusSuccess}
			data-error-message={formErrorMessage}
			data-missing-key-message={formStatusMissingKey}
			data-email-required={errors.emailRequired}
			data-email-invalid={errors.emailInvalid}
			data-message-required={errors.messageRequired}
			novalidate
		>
			<input
				type="checkbox"
				name="botcheck"
				class="hidden"
				tabindex="-1"
				autocomplete="off"
			/>
			<fieldset class="m-0 flex flex-col gap-5 border-0 p-0 sm:gap-6">
				<legend class="sr-only">{formAriaLabel}</legend>
				<InputField
					label={`${emailLabel}:`}
					type="email"
					id="email"
					name="email"
					placeholder={emailPlaceholder}
					required={true}
					showRequiredIndicator={false}
					ariaDescribedby="email-error"
				/>
				<TextAreaField
					label={`${messageLabel}:`}
					id="message"
					name="message"
					placeholders={messagePlaceholders}
					required={true}
					showRequiredIndicator={false}
					ariaDescribedby="message-error"
				/>
				<div
					class="mt-1 flex w-full flex-col gap-2 sm:flex-row sm:items-center sm:justify-between"
				>
					<span>
						<p
							id="contact-form-status"
							class="hidden text-small leading-none sm:text-right"
							role="status"
							aria-live="polite"
							aria-atomic="true"
						>
						</p>
					</span>
					<Button
						type="submit"
						aria-label={submitLabel}
						id="contact-submit"
						class="w-full md:w-auto"
					>
						{submitLabel}
					</Button>
				</div>
			</fieldset>
		</form>
	</div>
</section>

<script>
	import {
		submitContactForm,
		validateContactForm,
		type ContactFormMessages,
	} from '@/utils/contact-form'

	const form = document.getElementById('contact-form')
	const emailInput = document.getElementById('email')
	const messageInput = document.getElementById('message')
	const emailError = document.getElementById('email-error')
	const messageError = document.getElementById('message-error')
	const submitButton = document.getElementById('contact-submit')
	const formStatus = document.getElementById('contact-form-status')

	if (
		form instanceof HTMLFormElement &&
		emailInput instanceof HTMLInputElement &&
		messageInput instanceof HTMLTextAreaElement &&
		emailError instanceof HTMLElement &&
		messageError instanceof HTMLElement &&
		submitButton instanceof HTMLButtonElement &&
		formStatus instanceof HTMLElement
	) {
		let formStatusTimer: ReturnType<typeof setTimeout> | null = null
		const statusBaseClass = 'hidden text-small leading-none sm:text-right'
		const toneClasses = {
			neutral: 'text-black/80',
			success: 'text-green-700',
			error: 'text-red-700',
		}

		const formMessages: ContactFormMessages = {
			emailRequired: form.dataset.emailRequired ?? '',
			emailInvalid: form.dataset.emailInvalid ?? '',
			messageRequired: form.dataset.messageRequired ?? '',
		}

		const statusMessages = {
			success: form.dataset.successMessage ?? '',
			error: form.dataset.errorMessage ?? '',
			missingKey: form.dataset.missingKeyMessage ?? '',
			sendingLabel: form.dataset.sendingLabel ?? 'Sending...',
			submitLabel: form.dataset.submitLabel ?? 'Send Message',
		}

		const getFormValues = () => ({
			email: emailInput.value,
			message: messageInput.value,
		})

		const setFieldError = (
			input: HTMLInputElement | HTMLTextAreaElement,
			errorElement: HTMLElement,
			message = '',
		) => {
			const hasError = Boolean(message)
			input.setAttribute('aria-invalid', hasError ? 'true' : 'false')
			errorElement.textContent = message
			errorElement.classList.toggle('sr-only', !hasError)
		}

		const applyValidationState = () => {
			const validation = validateContactForm(getFormValues(), formMessages)
			setFieldError(emailInput, emailError, validation.fieldErrors.email)
			setFieldError(messageInput, messageError, validation.fieldErrors.message)
			return validation
		}

		const hideFormStatus = () => {
			if (formStatusTimer) {
				clearTimeout(formStatusTimer)
				formStatusTimer = null
			}

			formStatus.textContent = ''
			formStatus.className = statusBaseClass
		}

		const showFormStatus = (
			message: string,
			tone: keyof typeof toneClasses = 'neutral',
		) => {
			formStatus.textContent = message
			formStatus.className = `${statusBaseClass.replace('hidden ', '')} ${toneClasses[tone]}`

			if (tone === 'success') {
				formStatusTimer = setTimeout(() => {
					hideFormStatus()
				}, 5000)
			}
		}

		const setSubmittingState = (isSubmitting: boolean) => {
			submitButton.disabled = isSubmitting
			submitButton.setAttribute(
				'aria-disabled',
				isSubmitting ? 'true' : 'false',
			)
			submitButton.textContent = isSubmitting
				? statusMessages.sendingLabel
				: statusMessages.submitLabel
		}

		const clearValidationState = () => {
			setFieldError(emailInput, emailError, '')
			setFieldError(messageInput, messageError, '')
		}

		form.addEventListener('submit', async (event) => {
			event.preventDefault()
			hideFormStatus()

			const validation = applyValidationState()
			if (!validation.isValid) {
				if (validation.firstInvalidField === 'email') {
					emailInput.focus()
				} else if (validation.firstInvalidField === 'message') {
					messageInput.focus()
				}
				return
			}

			const accessKey = form.dataset.accessKey?.trim() ?? ''
			if (!accessKey) {
				console.error(
					'Missing PUBLIC_WEB3FORMS_ACCESS_KEY. Add it to your environment to enable the contact form.',
				)
				showFormStatus(statusMessages.missingKey, 'error')
				return
			}

			setSubmittingState(true)

			try {
				await submitContactForm({
					form,
					accessKey,
					subject: form.dataset.subject ?? '',
					values: validation.values,
				})

				form.reset()
				clearValidationState()
				hideFormStatus()
				showFormStatus(statusMessages.success, 'success')
			} catch (error) {
				console.error(error)
				showFormStatus(statusMessages.error, 'error')
			} finally {
				setSubmittingState(false)
			}
		})

		emailInput.addEventListener('input', () => {
			hideFormStatus()
			const validation = validateContactForm(getFormValues(), formMessages)
			setFieldError(emailInput, emailError, validation.fieldErrors.email)
		})

		messageInput.addEventListener('input', () => {
			hideFormStatus()
			const validation = validateContactForm(getFormValues(), formMessages)
			setFieldError(messageInput, messageError, validation.fieldErrors.message)
		})
	}
</script>
