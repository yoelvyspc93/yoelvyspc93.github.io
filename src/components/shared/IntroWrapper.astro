---
import DualOrbs from '@/shared/DualOrbs.astro'
---

<div class="relative overflow-hidden isolate">
	<div
		aria-hidden="true"
		role="presentation"
		class="pointer-events-none absolute inset-0 z-0 bg-white"
	>
	</div>

	<div
		aria-hidden="true"
		role="presentation"
		class="pointer-events-none absolute inset-0 z-10"
	>
		<div class="absolute -right-2 -top-24 opacity-90">
			<DualOrbs variant="left" />
		</div>
		<div class="absolute bottom-[30%] -left-1 opacity-80">
			<DualOrbs variant="right" />
		</div>
	</div>

	<div
		aria-hidden="true"
		role="presentation"
		class="pointer-events-none absolute inset-0 z-20 bg-section"
	>
	</div>

	<div
		aria-hidden="true"
		role="presentation"
		class="pointer-events-none absolute inset-0 z-30 bg-texture"
	>
	</div>
	<div class="relative z-40">
		<slot />
	</div>
</div>
