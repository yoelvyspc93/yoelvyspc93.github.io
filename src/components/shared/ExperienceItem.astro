---
import { Image } from 'astro:assets'

type Period = { start: string; end: string }

type ExperienceItemData = {
	period: Period
	company: string
	rol: string
	author: string
	datePublished: Date
	dateModified: Date
	image?: string[]
	Content: any
}

export interface Props {
	item: ExperienceItemData
	index: number
}

const { item, index } = Astro.props

const headingId = `experience-item-${index}-company`
const periodId = `experience-item-${index}-period`
const roleId = `experience-item-${index}-role`

const getDateTime = (value: string) => (value === 'Present' ? '9999' : value)

const startDateTime = getDateTime(item.period.start)
const endDateTime = getDateTime(item.period.end)

const dateLabel = `${item.period.start} - ${item.period.end}`
const formatDate = (date: Date) =>
	new Intl.DateTimeFormat('en', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	}).format(date)
---

<li class="relative">
	<div
		aria-hidden="true"
		class="absolute top-2
      left-[calc(clamp(22px,7vw,50px)-clamp(52px,12vw,120px)+2px)]
      -translate-x-1/2
      w-6 h-6 rounded-full
      bg-primary
      shadow-[0_0_0_4px_rgba(134,167,255,0.18)]"
	>
	</div>

	<article
		class="grid grid-cols-1 gap-6
      lg:grid-cols-[clamp(180px,24vw,280px)_1fr]
      lg:gap-x-[clamp(24px,5vw,64px)] lg:gap-y-6"
		aria-labelledby={headingId}
		aria-describedby={`${periodId} ${roleId}`}
	>
		<header class="text-left flex flex-col gap-1">
			<h3 id={headingId} class="font-bold text-heading-6">
				{item.company}
			</h3>

			<p id={periodId} class="text-small">
				<span class="sr-only"> {` ${dateLabel} `}</span>
				<time datetime={startDateTime}>{item.period.start}</time>
				<span aria-hidden="true">{' - '}</span>
				<time datetime={endDateTime}>{item.period.end}</time>
			</p>

			<p id={roleId} class="text-small">
				{item.rol}
			</p>
			<p class="sr-only">
				By {item.author}
				{' | '}
				Published{' '}
				<time datetime={item.datePublished.toISOString()}>
					{formatDate(item.datePublished)}
				</time>
				{' | '}
				Updated{' '}
				<time datetime={item.dateModified.toISOString()}>
					{formatDate(item.dateModified)}
				</time>
			</p>
		</header>

		<div class="w-full max-w-[720px]">
			<div
				class="text-large text-pretty leading-normal [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mb-2 [&_li]:mt-2"
			>
				<item.Content />
			</div>

			{
				item.image?.length ? (
					<figure class="mt-[clamp(12px,2vw,20px)]">
						<figcaption class="sr-only">{item.company}</figcaption>

						<ul class="grid grid-cols-1 gap-[clamp(12px,2vw,20px)] list-none p-0 sm:grid-cols-2">
							{item.image.map((img, imgIndex) => (
								<li class="list-none pb-4">
									<div
										class="relative flex aspect-[4/2.4] items-center overflow-hidden rounded-xl outline-1 outline-white/5"
										data-parallax-frame
									>
										<div
											class="w-full will-change-transform"
											data-parallax-media
											data-parallax-depth="24"
										>
											<Image
												src={`/images/projects/${img}.webp`}
												alt={`${item.company} screenshot ${imgIndex + 1}`}
												width={800}
												height={600}
												loading="lazy"
												decoding="async"
												class="block w-full h-auto"
											/>
										</div>
									</div>
								</li>
							))}
						</ul>
					</figure>
				) : null
			}
		</div>
	</article>
</li>
